[clone]
  defaultremotename = upstream
[checkout]
  defaultRemote = upstream
[init]
  defaultBranch = main
[core]
  excludesfile = ~/.gitignore-global
[includeIf "gitdir:~/Projects/Work"]
  path = ~/.gitconfig-work
[includeIf "gitdir:~/Projects/Personal"]
  path = ~/.gitconfig-personal
[includeIf "gitdir:~/Developer/"]
  path = ~/.gitconfig-personal
[credential]
  helper = osxkeychain
[pager]
  diff = delta
  log = delta
  reflog = delta
  show = delta
[delta]
  side-by-side = true
[pull]
  ff = only
  rebase = true
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[http]
  cookiefile = /Users/cypher/.gitcookies
